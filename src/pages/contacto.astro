						</div>
					</div>

					<div class="mt-12 space-y-4">
						<a href="mailto:villavicenciobiodigestores@outlook.com" class="flex items-center gap-4 text-lg font-bold hover:text-primary transition-colors">
							<span class="material-symbols-outlined text-primary">mail</span>
							villavicenciobiodigestores@outlook.com
						</a>
						<a href="#" class="flex items-center gap-4 text-lg font-bold hover:text-primary transition-colors">
							<span class="material-symbols-outlined text-primary">facebook</span>
							Villavicencio Biodigestores
						</a>
					</div>
				</section>
			</div>
		</div>
	</main>

	<Footer />
</Layout>
