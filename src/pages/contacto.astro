							<p class="text-slate-500">3484504524</p>
						</div>

						<!-- Cosquin -->
						<div class="glass-card p-6 rounded-xl">
							<h3 class="font-bold text-lg mb-2 text-primary">Cosquin - CBA</h3>
							<p class="text-sm font-medium">Carlos Sahakian</p>
							<p class="text-slate-500">3415415954</p>
						</div>

						<!-- Estancia Grande -->
						<div class="glass-card p-6 rounded-xl">
							<h3 class="font-bold text-lg mb-2 text-primary">Estancia Grande - SL</h3>
							<p class="text-sm font-medium">Marcela Sassy</p>
							<p class="text-slate-500">011 1549152540</p>
						</div>

						<!-- Merlo -->
						<div class="glass-card p-6 rounded-xl">
							<h3 class="font-bold text-lg mb-2 text-primary">Villa de Merlo</h3>
							<p class="text-sm font-medium">Claudia Fernandez</p>
							<p class="text-slate-500">2645065453</p>
						</div>

						<!-- San Juan -->
						<div class="glass-card p-6 rounded-xl">
